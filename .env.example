# Frontend mode. Use "demo" for the no-wallet walkthrough, "live" after deployment.
VITE_APP_MODE=demo

# Avalanche Fuji
VITE_FUJI_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
VITE_FUJI_EXPLORER=https://testnet.snowtrace.io

# Hardhat deployment. Never commit a funded private key.
FUJI_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
DEPLOYER_PRIVATE_KEY=
INITIAL_ADMIN_ADDRESS=
# Comma-separated creator/sender wallets allowed to register and record tips.
INITIAL_APPROVED_WALLETS=
SNOWTRACE_API_KEY=

# Filled after `npm run deploy:fuji`.
VITE_TIP_REGISTRY_ADDRESS=
# Used once by `npm run register:creator` from the approved creator wallet.
TIP_REGISTRY_ADDRESS=
CREATOR_HANDLE=

# Official Ava Labs eERC standalone/converter deployment for your demo.
VITE_EERC_CONTRACT_ADDRESS=
VITE_EERC_UNDERLYING_TOKEN_ADDRESS=

# The matching official eERC proving assets are bundled in
# public/circuits/official. No VITE_EERC_*_WASM or *_ZKEY values are needed.
